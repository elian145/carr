## kk backend example env (DO NOT commit real secrets)
APP_ENV=development

# REQUIRED in production
SECRET_KEY=REPLACE_ME
JWT_SECRET_KEY=REPLACE_ME

# Database
DATABASE_URL=postgresql://user:pass@host:5432/car_listings

# Redis (rate limiting / jobs)
REDIS_URL=redis://localhost:6379/0

# Socket.IO multi-worker scaling
# Use Redis as a message queue so broadcasts work across Gunicorn workers.
# Defaults to REDIS_URL in production when unset.
SOCKETIO_MESSAGE_QUEUE=

# Celery (async jobs)
# Defaults to REDIS_URL when unset.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Logging / observability
# - LOG_JSON=true emits one JSON log line per request (recommended in production)
LOG_LEVEL=INFO
LOG_JSON=true
REQUEST_ID_HEADER=X-Request-ID

# Monitoring (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Email
# Signup confirmation link: set PUBLIC_BASE_URL so the email uses https (e.g. https://api.yourdomain.com).
# If unset, the email will use carzo:// which only opens when the app is installed and the link is opened on that device.
# PUBLIC_BASE_URL=https://api.yourdomain.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=REPLACE_ME
MAIL_PASSWORD=REPLACE_ME
MAIL_DEFAULT_SENDER=REPLACE_ME

# Firebase (push)
FIREBASE_SERVER_KEY=REPLACE_ME
FIREBASE_PROJECT_ID=REPLACE_ME

# Where uploaded listing photos/videos and profile images are stored on disk.
# REQUIRED on hosts with an ephemeral filesystem (Docker, Render, Heroku, etc.):
# mount a persistent volume and set this to a path on that volume, e.g. /data/uploads
# Otherwise files disappear on redeploy/restart while DB rows still point at old URLs → HTTP 404.
# UPLOAD_FOLDER=/data/uploads

# Cloudflare R2 (optional – object storage)
# When fully configured (including R2_PUBLIC_URL), new listing VIDEOS from POST /api/cars/<id>/videos
# are uploaded to the bucket (car_videos/...) and the DB stores a public HTTPS URL (survives Render redeploys).
# Presigned PUT: POST /api/media/r2/sign-upload — use "asset":"image" (default) or "asset":"video".
# R2_ACCOUNT_ID=your-account-id
# R2_ACCESS_KEY_ID=REPLACE_ME
# R2_SECRET_ACCESS_KEY=REPLACE_ME
# R2_BUCKET_NAME=your-bucket
# Public base URL for objects (r2.dev subdomain or Custom Domain to the bucket)
# R2_PUBLIC_URL=https://pub-xxx.r2.dev
