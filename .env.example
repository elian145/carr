## Example environment file (DO NOT commit real secrets)
#
# Copy to `.env` locally if needed.
# Production should use a secret manager or CI-provided environment variables.
#
# SMS provider (example)
SMS_PROVIDER=infobip
INFOBIP_BASE_URL=https://YOUR_INSTANCE.api.infobip.com
INFOBIP_API_KEY=REPLACE_ME
INFOBIP_SENDER=REPLACE_ME

# Optional: local / docs only. On Render set OPENAI_API_KEY in the service Environment (never commit real keys).
# OPENAI_API_KEY=REPLACE_ME
# OPENAI_MODEL=gpt-4o-mini