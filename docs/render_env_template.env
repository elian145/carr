# Render production environment template
# Copy values into the Render web service Environment tab.
# See docs/DEPLOY_ENV_CHECKLIST.md for full instructions.

APP_ENV=production
SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32
JWT_SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32
DATABASE_URL=postgresql://user:pass@host/dbname

# Rate limiting + Socket.IO across workers (required for production)
REDIS_URL=redis://default:password@host:6379

# Upload persistence — Option A: Cloudflare R2 (recommended)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Upload persistence — Option B: Render persistent disk
# UPLOAD_FOLDER=/data/uploads

# App links (listing share URLs open in app)
APPLE_TEAM_ID=XXXXXXXXXX
ANDROID_SHA256_CERT_FINGERPRINTS=AA:BB:CC:...

# Push notifications
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Trust / legal (store listing)
SUPPORT_EMAIL=support@yourdomain.com
SUPPORT_PHONE=
TERMS_URL=
PRIVACY_URL=

# Optional
SENTRY_DSN=
AIRBRIDGE_APP_NAME=
AIRBRIDGE_APP_TOKEN=
